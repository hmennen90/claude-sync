{
  "name": "claude-device-sync",
  "version": "0.2.0",
  "description": "Cross-device session storage, shared memory, and reminders for Claude Code",
  "type": "module",
  "bin": {
    "device-sync": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "tsc && node --test dist/test/*.test.js",
    "preversion": "npm run build && npm test",
    "version": "node scripts/sync-version.js && git add .claude-plugin/plugin.json",
    "postversion": "git push && git push --tags",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    ".claude-plugin/**",
    "skills/**",
    "hooks/**",
    "scripts/**",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "sync",
    "session",
    "memory",
    "reminders",
    "cross-device",
    "team",
    "encrypted",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hmennen90/claude-device-sync.git"
  },
  "homepage": "https://github.com/hmennen90/claude-device-sync#readme",
  "bugs": {
    "url": "https://github.com/hmennen90/claude-device-sync/issues"
  },
  "license": "MIT",
  "author": "Hendrik Mennen",
  "dependencies": {
    "argon2": "^0.41.1",
    "commander": "^13.1.0",
    "inquirer": "^12.6.0",
    "simple-git": "^3.27.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "typescript": "^5.8.3"
  }
}
